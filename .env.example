# SpringLens — Environment Variables Template
# Copy to .env and fill in your values
# For local dev WITHOUT docker, these are sourced by run-local.sh

# ── GitHub OAuth (create at https://github.com/settings/developers) ──────────
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# ── Stripe (get from https://dashboard.stripe.com/test/apikeys) ──────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Auth Service ──────────────────────────────────────────────────────────────
# Minimum 256-bit random string: openssl rand -hex 32
JWT_SECRET=change-me-in-production-minimum-256-bits

# ── Next.js Auth ──────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production

# ── Database (local — no Docker) ──────────────────────────────────────────────
DB_PASSWORD=springlens_dev

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
